# OpenTeacher - 开放智慧助教 环境变量示例
# 复制此文件为 .env 并填写真实配置

# 基础配置
PORT=5000
HOSTNAME=localhost
COZE_PROJECT_ENV=DEV

# ==========================================
# LLM服务配置
# ==========================================

# LLM服务提供商（可选：openai 或 volcengine）
LLM_PROVIDER=volcengine

# 火山引擎配置
VOLCENGINE_API_KEY=your_volcengine_api_key
VOLCENGINE_SERVICE_ID=your_service_id
VOLCENGINE_MODEL=your_model_name
# VOLCENGINE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# OpenAI配置
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=https://api.openai.com/v1

# ==========================================
# Supabase数据库配置
# ==========================================

COZE_SUPABASE_URL=https://your-project.supabase.co
COZE_SUPABASE_ANON_KEY=your_anon_key
COZE_SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ==========================================
# 对象存储配置（可选）
# ==========================================

STORAGE_ENDPOINT=https://your-storage-endpoint
STORAGE_ACCESS_KEY=your_access_key
STORAGE_SECRET_KEY=your_secret_key
STORAGE_BUCKET_NAME=your_bucket_name

# ==========================================
# 其他可选配置
# ==========================================

# 音频服务相关
ASR_ENDPOINT=https://your-asr-endpoint
TTS_ENDPOINT=https://your-tts-endpoint

# 图像生成
IMAGE_GENERATION_ENDPOINT=https://your-image-generation-endpoint
IMAGE_GENERATION_KEY=your_image_generation_key